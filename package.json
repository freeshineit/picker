{
  "name": "picker",
  "version": "0.0.0",
  "description": "pnpm workspace",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel --filter '*' dev",
    "build": "pnpm run --filter '*' build",
    "build:picker": "pnpm run --filter @skax/picker build",
    "clean": "pnpm run --parallel --filter '*' clean && rimraf node_modules",
    "clean:dist": "rimraf 'packages/*/dist' 'examples/*/dist'",
    "lint": "eslint --fix \"packages/*/src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\" \"examples/*/src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\"",
    "lint:check": "eslint \"packages/*/src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\" \"examples/*/src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\"",
    "fmt": "prettier --write \"./**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml,vue,cjs}\"",
    "fmt:check": "prettier --check \"./**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml,vue,cjs}\"",
    "type-check": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "list": "lerna list",
    "release": "lerna publish",
    "version": "lerna version",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:pw": "playwright test",
    "test:pw:debug": "playwright test --debug",
    "test:pw:headed": "playwright test --headed",
    "test:pw:ui": "playwright test --ui",
    "test:pw:report": "playwright show-report",
    "docs": "typedoc --options typedoc.config.mjs"
  },
  "files": [],
  "keywords": [],
  "author": "ShineShao <xiaoshaoqq@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@skax/rollup-config": "^0.1.0",
    "@babel/preset-env": "^7.27.2",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.13",
    "eslint": "^9.39.4",
    "eslint-config-xx": "^2.2.3",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-transform-stub": "^2.0.0",
    "lerna": "8.2.4",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.2",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typedoc-plugin-replace-text": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.3",
    "react": ">=17"
  },
  "publishConfig": {
    "access": "public"
  }
}
