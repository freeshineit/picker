{
  "name": "@skax/picker",
  "version": "1.2.0-alpha.1",
  "description": "picker component for js framework, support mobile and pc",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./dist/style/css.css": "./dist/style/css.css",
    "./dist/style/css.js": "./dist/style/css.js",
    "./dist/style/index.js": "./dist/style/index.js",
    "./dist/style": "./dist/style/index.js"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development rollup --config rollup.config.mjs --watch",
    "build": "pnpm run clean && cross-env NODE_ENV=production rollup --config rollup.config.mjs && pnpm run docs",
    "docs": "rimraf docs && typedoc --out docs src/index.ts",
    "clean": "rimraf dist docs temp",
    "lint": "eslint --fix \"./src/*.{ts,tsx,js,jsx,mjs}\"",
    "fmt": "prettier --write \"./**/*.{ts,tsx,js,mjs,jsx,html,scss,sass}\" \"./*.{ts,tsx,js,mjs,jsx,html,scss,sass}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "picker"
  ],
  "author": "ShineShao <xiaoshaoqq@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-typescript": "^7.26.0",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-eslint": "^9.0.5",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-strip": "^3.0.4",
    "@rollup/plugin-swc": "^0.4.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@swc/core": "^1.11.29",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "cssnano": "^7.0.7",
    "dayjs": "^1.11.13",
    "eslint": "^9.39.4",
    "eslint-config-xx": "^2.2.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.41.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^2.0.3",
    "sass": "^1.89.0",
    "ts-jest": "^29.2.5",
    "typedoc": "^0.28.14",
    "typedoc-plugin-mdn-links": "^5.0.10",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typedoc-plugin-replace-text": "^4.2.0",
    "typescript": "5.3.3"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "browserslist": {
    "development": [
      "last 1 version"
    ],
    "production": [
      "> 1%",
      "not dead"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeshineit/picker.git"
  },
  "bugs": {
    "url": "https://github.com/freeshineit/picker/issues"
  },
  "homepage": "https://freeshineit.github.io/picker/"
}
